#!hexa strict
// tests/test_n6_lattice.hexa — n=6 master identity unit tests.
//
// Mirrors hexa-sscb/tests/test_acceptance.py auto-runnable subset: each
// claim runs against bench-independent state and exits non-zero on first
// failure. Bench-only items are listed as comments at the bottom.

fn _gcd(a: int, b: int) -> int {
    let mut x = a; let mut y = b
    if x < 0 { x = -x }
    if y < 0 { y = -y }
    while y != 0 { let t = y; y = x % y; x = t }
    return x
}

fn euler_phi(n: int) -> int {
    if n == 1 { return 1 }
    let mut c = 0; let mut k = 1
    while k <= n { if _gcd(k, n) == 1 { c = c + 1 }; k = k + 1 }
    return c
}

fn divisors(n: int) -> [int] {
    let mut d: [int] = []
    let mut k = 1
    while k <= n { if n % k == 0 { d = d + [k] }; k = k + 1 }
    return d
}

fn sigma_n(n: int) -> int {
    let mut s = 0
    for d in divisors(n) { s = s + d }
    return s
}

fn tau_n(n: int) -> int { return divisors(n).len() }

fn test(label: str, ok: bool) {
    if ok {
        println("  [PASS] " + label)
    } else {
        println("  [FAIL] " + label)
        exit(1)
    }
}

fn main() {
    println("========================================================================")
    println("  hexa-chip — tests/test_n6_lattice.hexa")
    println("========================================================================")
    test("σ(6) = 12",            sigma_n(6) == 12)
    test("τ(6) = 4",             tau_n(6) == 4)
    test("φ(6) = 2",             euler_phi(6) == 2)
    test("σ(6)·φ(6) = 24",       sigma_n(6) * euler_phi(6) == 24)
    test("n·τ(6) = 24",          6 * tau_n(6) == 24)
    test("σ·φ = n·τ identity",   sigma_n(6) * euler_phi(6) == 6 * tau_n(6))

    // n=6 is special: master identity holds at n=1 and n=6 in 1..12 range.
    let mut nspecial = 0
    let mut k = 1
    while k <= 12 {
        if sigma_n(k) * euler_phi(k) == k * tau_n(k) { nspecial = nspecial + 1 }
        k = k + 1
    }
    test("master identity holds at exactly 2 of 1..12 (n=1,6)", nspecial == 2)

    // J₂ = 24 = σ(6)·φ(6)
    test("J₂ = 24 = σ·φ",        sigma_n(6) * euler_phi(6) == 24)

    // BOM-lattice: σ(6)=12 admits 9 active + 3 reserved (sscb-pattern reuse)
    let active = 9
    let reserved = 3
    test("BOM lattice 9+3 = σ(6)=12", active + reserved == sigma_n(6))

    // Layer ceiling: J₂=24 maps to interconnect M-layer cap
    test("interconnect ceiling = J₂ = 24", 24 == sigma_n(6) * euler_phi(6))

    println("========================================================================")
    println("  9/9 invariants PASS  —  n=6 master identity intact across all surfaces")
    println("========================================================================")
}
